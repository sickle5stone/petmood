# ──────────────────────────────────────────────────────────────────────────────
# PetMood environment variables
# Copy to .env and fill in only the services you want to enable.
# The app runs fully in demo/mock mode without any of these.
# ──────────────────────────────────────────────────────────────────────────────

# ── Firebase / Firestore ───────────────────────────────────────────────────────
# Required for cloud data persistence.
# Create a project at https://console.firebase.google.com
# Enable Firestore in Native mode with the MVP rules in firestore.rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Analysis backend (VLM) ────────────────────────────────────────────────────
# URL of your analysis endpoint.
# Contract: POST multipart/form-data { video: File }
# Success 200: { activity, feeling, confidence, evidence[], keyframeCount }
# Error non-2xx: { error: "NO_CAT" | "MULTIPLE_CATS" | "TOO_SHORT" | "UNREADABLE" }
# When unset the app returns mock reads after ~2.8 s (demo/offline mode).
VITE_ANALYSIS_API_URL=
# VITE_ANALYSIS_ENDPOINT=  ← legacy alias for the above; either works

# ── Dev / test hooks (mock mode only — ignored when a real endpoint is set) ───
# Force a specific typed error in the mock analyser:
#   VITE_ANALYSIS_MOCK_ERROR=NO_CAT
#   VITE_ANALYSIS_MOCK_ERROR=MULTIPLE_CATS
#   VITE_ANALYSIS_MOCK_ERROR=TOO_SHORT
#   VITE_ANALYSIS_MOCK_ERROR=UNREADABLE
#   VITE_ANALYSIS_MOCK_ERROR=GENERIC
VITE_ANALYSIS_MOCK_ERROR=

# Return a specific mock read by index (0–5) instead of a random one:
VITE_ANALYSIS_MOCK_INDEX=
